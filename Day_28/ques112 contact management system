#include <stdio.h>

int main() {
    char name[50], email[50];
    long long mobile;

    printf("===== CONTACT MANAGEMENT SYSTEM =====\n");

    printf("Enter Name: ");
    scanf("%s", name);

    printf("Enter Mobile Number: ");
    scanf("%lld", &mobile);

    printf("Enter Email ID: ");
    scanf("%s", email);

    printf("\n----- SAVED CONTACT -----\n");
    printf("Name   : %s\n", name);
    printf("Mobile : %lld\n", mobile);
    printf("Email  : %s\n", email);

    return 0;
}
