#include <stdio.h>

int main() {
    int bookId;
    char bookName[50], author[50];
    int days;
    float fine = 0;

    printf("===== LIBRARY MANAGEMENT SYSTEM =====\n");

    printf("Enter Book ID: ");
    scanf("%d", &bookId);

    printf("Enter Book Name: ");
    scanf("%s", bookName);

    printf("Enter Author Name: ");
    scanf("%s", author);
    
    printf("****fine per day is 5rs****");
    printf("\n****fine on keeping the book beyond 15 days****");

    printf("\nEnter Number of Days Book is Kept: ");
    scanf("%d", &days);

    if (days > 15)
        fine = (days - 15) * 5;

    printf("\n----- BOOK DETAILS -----\n");
    printf("Book ID : %d\n", bookId);
    printf("Book Name : %s\n", bookName);
    printf("Author : %s\n", author);
    printf("Fine : Rs. %f\n", fine);

    return 0;
}
