#include <stdio.h>

int main() {
    int arr[100], n, i;
    int choice, sum = 0, max, min, key, found = 0;

    printf("Enter size of array: ");
    scanf("%d", &n);

    printf("Enter array elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    printf("\n===== ARRAY OPERATIONS =====");
    printf("\n1. Display Array");
    printf("\n2. Sum of Elements");
    printf("\n3. Find Maximum");
    printf("\n4. Find Minimum");
    printf("\n5. Search an Element");
    printf("\n6. Reverse Array");
    printf("\nEnter your choice: ");
    scanf("%d", &choice);

    switch(choice)
    {
        case 1:
            printf("Array Elements: ");
            for(i = 0; i < n; i++)
                printf("%d ", arr[i]);
            break;

        case 2:
            for(i = 0; i < n; i++)
                sum += arr[i];
            printf("Sum = %d", sum);
            break;

        case 3:
            max = arr[0];
            for(i = 1; i < n; i++)
                if(arr[i] > max)
                    max = arr[i];
            printf("Maximum = %d", max);
            break;

        case 4:
            min = arr[0];
            for(i = 1; i < n; i++)
                if(arr[i] < min)
                    min = arr[i];
            printf("Minimum = %d", min);
            break;

        case 5:
            printf("Enter element to search: ");
            scanf("%d", &key);

            for(i = 0; i < n; i++)
            {
                if(arr[i] == key)
                {
                    printf("Element found at position %d", i + 1);
                    found = 1;
                    break;
                }
            }

            if(found == 0)
                printf("Element not found");
            break;

        case 6:
            printf("Reversed Array: ");
            for(i = n - 1; i >= 0; i--)
                printf("%d ", arr[i]);
            break;

        default:
            printf("Invalid Choice");
    }

    return 0;
}
