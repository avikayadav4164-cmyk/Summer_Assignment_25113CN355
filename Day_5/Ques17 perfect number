#include<stdio.h>
int main()
{
int number,i,sum=0;
scanf("enter the number-");
printf("%d",&number);
//finding the factors of the number
for(i=1;i<number;i++)
{
if(number%i==0)
{
sum=sum+i;
}
}
if(sum==number)
printf("%d is a perfect number",number);
else
printf("%d is not a perfect number",number);
return 0;
}
