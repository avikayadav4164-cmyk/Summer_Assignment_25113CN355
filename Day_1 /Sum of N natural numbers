#include<stdio.h>
int main()
{ 
int sum=0,n,i;
 //entering the number upto which sum has to be print
printf("enter the value of 'n':");
scanf("%d",&n);
//running the loop till 'n' to calculate the sum
for(i=1;i<=n;i++)  
{
sum=sum+i;
}
//printing the sum of the first n natural numbers
printf("Sum of first N natural numbers is %d",sum);
return 0;
}
//closing the main function
