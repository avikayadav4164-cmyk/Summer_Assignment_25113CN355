#include <stdio.h>

int main() {
int number, reverse = 0, digit;

printf("Enter a number: ");
scanf("%d", &number);

while (number != 0) {
digit = number % 10; // Extract last digit
reverse = reverse * 10 + digit; // Append digit to reverse
number /= 10; // Remove last digit
}

printf("Reversed number = %d\n", reverse);

return 0;
}
