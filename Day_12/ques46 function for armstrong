#include <stdio.h>

int armstrong(int n)
{
 int num=n;
int c=0,d,sum=0;
  while(num!=0)
{
   d=num%10;
   c++;
}
    while(num!=0)
     {
  d=num%10;
  sum=sum+pow(d,c);
  num=num/10;
     }
return sum;
}

int main()
{
    int n;
    int a;
     printf("Enter a number: ");
    scanf("%d", &n);
    a=armstrong(n);
   if(a==n)
   printf("number %d is armstrong",n);
else
printf("number %d is not armstrong",n);\
return 0;
