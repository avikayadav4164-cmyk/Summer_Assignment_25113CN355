#include <stdio.h>

//using no parameter with no return type of function

void fibo() 
{
    int n, i;
    int first = 0, second = 1, next;

    printf("Enter the number of terms: ");
    scanf("%d", &n);

    printf("Fibonacci Series: ");

    for (i = 1; i <= n; i++) {
        printf("%d ", first);

        next = first + second;
        first = second;
        second = next;
    }
}
int main()
{
fibo();
 return 0;
}
