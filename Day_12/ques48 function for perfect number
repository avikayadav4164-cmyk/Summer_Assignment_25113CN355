#include <stdio.h>

int perfect(int n)
{
 int i,sum=0;
for(i=1;i<n;i++)
{
sum=sum+i;
}
    return sum;
}

int main()
{
    int n;
    int a;
     printf("Enter a number: ");
    scanf("%d", &n);
    a=perfect(n);
   if(a==n)
   printf("number %d is perfect number",n);
else
printf("number %d is not perfect number",n);
    return 0;
}
