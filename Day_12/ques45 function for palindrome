#include <stdio.h>

int palindrome(int n)
{
 int num=n;
int rev=0,d;
  while(num!=0)
{
   d=num%10;
   rev=rev*10+d;
   num=num/10;
}
    return rev;
}

int main()
{
    int n;
    int a;
     printf("Enter a number: ");
    scanf("%d", &n);
    a=palindrome(n);
   if(a==n)
   printf("number %d is palindrome",n);
else
printf("number %d is not palindrome",n);
    return 0;
}
