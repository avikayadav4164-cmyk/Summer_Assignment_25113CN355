#include <stdio.h>

int main() {
    int a[10][10], n, sum = 0;

    printf("Enter order of square matrix: ");
    scanf("%d", &n);

    printf("Enter matrix elements:\n");
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            scanf("%d", &a[i][j]);
        }
    }

    // Find sum of both diagonals
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            if(i == j || i + j == n - 1)
                sum += a[i][j];
        }
    }

    printf("Sum of both diagonals = %d", sum);

    return 0;
}
