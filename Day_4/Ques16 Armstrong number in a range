#include <stdio.h>
#include <math.h>

int main() {
    int start, end, num, original, digit, count;
    int sum;

    printf("Enter start and end of range: ");
    scanf("%d %d", &start, &end);

    printf("Armstrong numbers between %d and %d are:\n", start, end);

    for (num = start; num <= end; num++) {
        original = num;
        sum = 0;
        count = 0;

        // Count number of digits
        int temp = num;
        while (temp != 0) {
            count++;
            temp /= 10;
        }

        temp = num;

        // Calculate Armstrong sum
        while (temp != 0) {
            digit = temp % 10;
            sum += pow(digit, count);
            temp /= 10;
        }

        if (sum == original) {
            printf("%d ", original);
        }
    }

    return 0;
}
