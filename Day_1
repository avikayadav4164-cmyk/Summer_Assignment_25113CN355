#include <stdio.h>

int main() {
    int n, i, sum = 0;
    
    // Input: Get the value of N from user
    printf("Enter the value of N: ");
    scanf("%d", &n);
    
    // Calculate sum of first N natural numbers using loop
    for (i = 1; i <= n; i++) {
        sum += i;
    }
    
    // Output: Print the result
    printf("Sum of first %d natural numbers = %d\n", n, sum);
    
    return 0;
}
