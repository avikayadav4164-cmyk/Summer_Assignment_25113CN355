#include <stdio.h>
#include <string.h>

int main() {
    char str[100], longest[20];
    int i, len = 0, max = 0, start = 0, pos = 0;

    printf("Enter a sentence: ");
    fgets(str, 100, stdin);

    for (i = 0; ; i++) {

        if (str[i] == ' ' || str[i] == '\0' || str[i] == '\n') {

            if (len > max) {
                max = len;
                pos = start;
            }

            len = 0;
            start = i + 1;
        }
        else
            len++;

        if (str[i] == '\0')
            break;
    }

    strncpy(longest, str + pos, max);
    longest[max] = '\0';

    printf("Longest word = %s", longest);

    return 0;
}
